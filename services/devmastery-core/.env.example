# =============================================================
# DevMastery — Environment Variables
# Copy to .env and fill in. NEVER commit .env to git.
#
# All services below are FREE with NO CREDIT CARD required.
# =============================================================

# ─── Database (Supabase PostgreSQL — Transaction Pooler URL) ─
# Get it from: Supabase → Project Settings → Database → Connection String → "URI"
# Use the TRANSACTION POOLER variant (port 6543) for Render compatibility.
DATABASE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres?user=postgres.YOUR_PROJECT_REF&password=YOUR_PASSWORD
DATABASE_USERNAME=postgres.YOUR_PROJECT_REF
DATABASE_PASSWORD=your_supabase_db_password

# ─── Supabase Storage (1GB free, no credit card) ─────────────
# Get these from: Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Auth ────────────────────────────────────────────────────
# Must be at least 32 characters (HMAC-SHA256). Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_EXPIRY_MS=86400000

# ─── Google Gemini AI (free tier — no credit card) ───────────
# Get key: https://aistudio.google.com/app/apikey
# Free: 15 RPM, 1M tokens/day, 1500 RPD
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ─── Application ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
ALLOWED_ORIGINS=https://your-app.pages.dev
SERVER_PORT=8080

# ─── Keep-alive (configure in UptimeRobot, not here) ─────────
# UptimeRobot (free, no credit card): https://uptimerobot.com
# Create HTTP(s) monitor → URL: https://your-app.onrender.com/api/warmup
# Interval: 14 minutes (prevents Render spin-down + keeps Supabase active)

# ─── Solo Leveling Integration (THE SYSTEM webhook) ──────────
# Fires a webhook to THE SYSTEM when you complete a topic in DevMastery.
# Leave SOLO_LEVELING_WEBHOOK_URL blank to disable (feature-flagged).
# Set the same secret in THE SYSTEM's thesystem.devmastery.webhook-secret env var.
SOLO_LEVELING_WEBHOOK_URL=https://your-the-system-api.onrender.com/api/devmastery/webhook
SOLO_LEVELING_WEBHOOK_SECRET=CHANGE-ME-shared-secret-between-both-apps

