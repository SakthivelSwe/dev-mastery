# =============================================================
# DevMastery — Environment Variables (Dev)
# Copy this file to .env.dev and fill in real values.
# NEVER commit .env.dev to git.
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=devmastery
POSTGRES_USER=devmastery
POSTGRES_PASSWORD=CHANGE_ME_devmastery_secret

# ─── Valkey (Redis-compatible cache) ──────────────────────────
VALKEY_HOST=localhost
VALKEY_PORT=6379

# ─── OpenSearch ───────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# ─── Apache Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Judge0 CE (self-hosted code execution) ───────────────────
JUDGE0_BASE_URL=http://localhost:2358
# Judge0 also needs its own postgres and valkey connections:
JUDGE0_POSTGRES_PASSWORD=CHANGE_ME_judge0_secret

# ─── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_32chars_min

# ─── HashiCorp Vault ──────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME_root_token_dev_only

# ─── Google Gemini API (free tier) ────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_jwt_secret_key_here
JWT_EXPIRY_HOURS=24

# ─── Google OAuth2 (for Google Sign-In) ───────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ─── Email (Gmail SMTP — free 500/day) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# ─── Next.js Web App ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
