<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules (API 31+): cloud backup + device transfer.
   Exclude the Keystore-bound encrypted prefs so a restore/transfer can never
   deliver an unreadable blob that crashes EncryptedSharedPreferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="secure_prefs_fallback.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="secure_prefs_fallback.xml"/>
    </device-transfer>
</data-extraction-rules>