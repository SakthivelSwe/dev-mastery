<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules (API 31 and lower use this file).
   The encrypted token store is bound to the device Keystore, so restoring it
   onto another device produces an unreadable blob that crashes
   EncryptedSharedPreferences on first read. Never back it up.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secure_prefs.xml"/>
    <exclude domain="sharedpref" path="secure_prefs_fallback.xml"/>
</full-backup-content>