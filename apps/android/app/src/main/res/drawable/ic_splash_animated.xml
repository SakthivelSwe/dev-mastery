<?xml version="1.0" encoding="utf-8"?>
<!--
  DevMastery animated splash icon (Android 12+ SplashScreen API).
  The "</>" glyph draws itself in via a trim-path stroke animation while the
  whole group scales up with a subtle overshoot, then the launcher hands off
  to the app with a fade/zoom exit (handled in MainActivity).
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">
            <group
                android:name="root"
                android:pivotX="54"
                android:pivotY="54">
                <!-- Left chevron "<" -->
                <path
                    android:name="chevL"
                    android:pathData="M46,40 L30,54 L46,68"
                    android:strokeColor="#FFFFFFFF"
                    android:strokeWidth="5.5"
                    android:strokeLineCap="round"
                    android:strokeLineJoin="round"
                    android:fillColor="#00000000"
                    android:trimPathStart="0"
                    android:trimPathEnd="0" />
                <!-- Middle slash "/" -->
                <path
                    android:name="slash"
                    android:pathData="M50,71 L58,37"
                    android:strokeColor="#FFB9C4FF"
                    android:strokeWidth="5.5"
                    android:strokeLineCap="round"
                    android:strokeLineJoin="round"
                    android:fillColor="#00000000"
                    android:trimPathStart="0"
                    android:trimPathEnd="0" />
                <!-- Right chevron ">" -->
                <path
                    android:name="chevR"
                    android:pathData="M62,40 L78,54 L62,68"
                    android:strokeColor="#FFFFFFFF"
                    android:strokeWidth="5.5"
                    android:strokeLineCap="round"
                    android:strokeLineJoin="round"
                    android:fillColor="#00000000"
                    android:trimPathStart="0"
                    android:trimPathEnd="0" />
            </group>
        </vector>
    </aapt:attr>

    <!-- Group: gentle overshoot scale-up -->
    <target android:name="root">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.55"
                    android:valueTo="1.0"
                    android:duration="600"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.55"
                    android:valueTo="1.0"
                    android:duration="600"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>

    <!-- Left chevron draws in first -->
    <target android:name="chevL">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="80"
                android:duration="360"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Slash draws in next -->
    <target android:name="slash">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="220"
                android:duration="300"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Right chevron draws in last -->
    <target android:name="chevR">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="360"
                android:duration="360"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
</animated-vector>

