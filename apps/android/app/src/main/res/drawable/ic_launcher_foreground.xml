<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        DevMastery icon — "Rocket of Mastery"
        Concept: a sleek upward-pointing rocket (growth, learning, launching forward)
        with a glowing star trail. Uses warm white + soft gold/amber tones
        on the teal gradient background.

        Viewport: 108×108 (Android adaptive icon safe zone: 72×72 centred)
        All shapes are within the safe zone (18–90 range on both axes).
    -->

    <!-- ── Rocket body (rounded elongated diamond) ── -->
    <path
        android:pathData="
            M54,22
            C50,30 42,40 40,54
            C40,66 48,74 54,76
            C60,74 68,66 68,54
            C66,40 58,30 54,22Z"
        android:fillColor="#FFFFFFFF"
        android:strokeWidth="0" />

    <!-- Rocket body gradient overlay (warm amber tint at base) -->
    <path
        android:pathData="
            M54,22
            C50,30 42,40 40,54
            C40,66 48,74 54,76
            C60,74 68,66 68,54
            C66,40 58,30 54,22Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="22"
                android:endX="54"
                android:endY="76"
                android:type="linear">
                <item android:color="#00FFFFFF" android:offset="0.0" />
                <item android:color="#30FFD580" android:offset="0.7" />
                <item android:color="#60FFB347" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Window / porthole (teal circle) ── -->
    <path
        android:pathData="M54,48 A6,6,0,1,1,53.99,48Z"
        android:fillColor="#FF10A088"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.5" />

    <!-- ── Left fin ── -->
    <path
        android:pathData="M40,62 L32,72 L44,68 Z"
        android:fillColor="#FFE8F0EE"
        android:strokeWidth="0" />

    <!-- ── Right fin ── -->
    <path
        android:pathData="M68,62 L76,72 L64,68 Z"
        android:fillColor="#FFE8F0EE"
        android:strokeWidth="0" />

    <!-- ── Engine flame (amber/gold) ── -->
    <path
        android:pathData="M46,76 C46,82 50,88 54,86 C58,88 62,82 62,76 C58,79 50,79 46,76Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="76"
                android:endX="54"
                android:endY="88"
                android:type="linear">
                <item android:color="#FFFFD700" android:offset="0.0" />
                <item android:color="#FFFF8C00" android:offset="0.6" />
                <item android:color="#80FF4500" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Star / sparkle top-left (mastery accent) ── -->
    <path
        android:pathData="
            M30,32 L31.5,36 L35.5,36 L32.2,38.5 L33.8,42.5 L30,40 L26.2,42.5 L27.8,38.5 L24.5,36 L28.5,36Z"
        android:fillColor="#FFFFD700"
        android:strokeWidth="0" />

    <!-- ── Star / sparkle top-right (smaller) ── -->
    <path
        android:pathData="
            M78,26 L79,29 L82,29 L79.5,31 L80.5,34 L78,32.5 L75.5,34 L76.5,31 L74,29 L77,29Z"
        android:fillColor="#80FFFFFF"
        android:strokeWidth="0" />

</vector>