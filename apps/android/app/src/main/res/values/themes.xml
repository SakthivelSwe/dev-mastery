<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Splash theme used while the app process warms up. androidx.core.splashscreen
         installs it on Android 5+ and hands off to Theme.DevMastery once the first
         frame is ready. On Android 12+ the system renders the launcher icon on
         top of postSplashScreenTheme's window background. -->
    <style name="Theme.DevMastery.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg_primary</item>
        <!-- Animated "draw-in" glyph (Android 12+). Older APIs fall back to a
             static render of the same vector automatically. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_animated</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.DevMastery</item>
    </style>

    <style name="Theme.DevMastery" parent="android:Theme.Material.Light.NoActionBar" />
</resources>

