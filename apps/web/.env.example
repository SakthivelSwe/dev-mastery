# ─── Backend API ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Code Execution — Dual Provider (auto-fallback) ───────────────────────
# ONE API key — works for BOTH providers (same RapidAPI account).
# Primary is tried first; auto-falls back to secondary on rate-limit or error.
# Use identical values in .env.local (local) and Cloudflare Pages (production).
#
# Subscribe to both for free at:
#   Primary:  https://rapidapi.com/dishis-technologies-judge0/api/judge029
#   Fallback: https://rapidapi.com/judge0-official/api/judge0-ce

JUDGE0_API_KEY=your_rapidapi_key_here

JUDGE0_PRIMARY_URL=https://judge029.p.rapidapi.com
JUDGE0_PRIMARY_HOST=judge029.p.rapidapi.com

JUDGE0_FALLBACK_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_FALLBACK_HOST=judge0-ce.p.rapidapi.com
